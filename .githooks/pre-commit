#!/usr/bin/env bash
# Pre-commit hook: format, clippy, test
set -eo pipefail

echo "=== pre-commit: cargo fmt ==="
cargo fmt --check || {
    echo "Format check failed. Run 'cargo fmt' to fix."
    exit 1
}

echo "=== pre-commit: cargo clippy ==="
cargo clippy --workspace --tests -- -D warnings || {
    echo "Clippy failed. Fix warnings before committing."
    exit 1
}

echo "=== pre-commit: cargo test ==="
cargo test --workspace --lib --tests 2>&1 | tail -5 || {
    echo "Tests failed."
    exit 1
}

echo "=== pre-commit: all checks passed ==="
